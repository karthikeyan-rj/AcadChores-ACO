# ACO Backend Environment Variables
# Copy this file to .env and fill in your values

APP_ENV=development
HOST=127.0.0.1
PORT=8001

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_TIMEOUT_SECONDS=180

# MongoDB (set REDIS_ENABLED=false and provide MONGODB_URL to use in-memory fallback)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=aco

# Redis (set REDIS_ENABLED=false to use in-memory fallback)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Security (CHANGE THIS in production!)
SECRET_KEY=replace-with-a-long-random-secret

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting (slowapi, per-IP, in-memory by default)
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_WEBSOCKET=5/minute

# Logging
LOG_LEVEL=INFO

# Google OAuth (optional - only needed for Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Cloud Fallback Planner (optional)
# CLOUD_FALLBACK_ENABLED=false
# CLOUD_AI_PROVIDER=openai
# CLOUD_AI_MODEL=gpt-4o-mini
# CLOUD_AI_API_KEY=
# CLOUD_FALLBACK_MAX_ATTEMPTS=1
# CLOUD_FALLBACK_DAILY_LIMIT=20

# Local Planner Retry
# LOCAL_PLANNER_RETRY_COUNT=1
# WORKFLOW_MIN_QUALITY_SCORE=70

# Credential Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# CREDENTIAL_ENCRYPTION_KEY=
